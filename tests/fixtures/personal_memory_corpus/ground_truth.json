{
  "_meta": {
    "description": "Per-document extraction ground truth for the personal memory corpus. Used to benchmark extraction precision/recall under the expanded vocab + subtype model (see specs/vocab_expansion.md).",
    "canonical_rel_types": [
      "WORKS_FOR", "LEADS", "MEMBER_OF", "REPORTS_TO", "APPROVED", "USES",
      "BELONGS_TO", "LOCATED_IN", "CREATED", "RELATED_TO",
      "HAS_TITLE", "HAS_PREFERENCE", "HAS_ATTRIBUTE", "FAMILY_OF",
      "RECOMMENDED", "DISCUSSED", "HAPPENED_ON", "LIVES_IN"
    ],
    "canonical_entity_types": [
      "Person", "Organization", "Project", "Technology", "Location",
      "Concept", "Event", "Document", "Role", "DateTime", "Task"
    ],
    "functional_keys": {
      "WORKS_FOR": [], "LIVES_IN": [], "MARRIED_TO": [], "REPORTS_TO": [],
      "BELONGS_TO": [], "HAPPENED_ON": [],
      "HAS_TITLE": ["object"],
      "HAS_PREFERENCE": ["subtype"],
      "HAS_ATTRIBUTE": ["subtype"]
    },
    "relation_field_schema": {
      "subject": "canonical entity name",
      "object": "canonical entity name",
      "type": "canonical rel type from canonical_rel_types",
      "subtype": "snake_case nuance string, or null if the primitive suffices",
      "acceptable_synonyms": "list of rel_type strings the LLM may produce that should coerce to `type` — precision/recall scoring treats these as correct",
      "notes": "optional — clarifies edge cases (direction, implicit vs explicit, functionality trigger)"
    }
  },

