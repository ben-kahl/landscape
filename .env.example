COMPOSE_PROFILES=cpu

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=landscape-dev
QDRANT_URL=http://qdrant:6333
OLLAMA_URL=http://ollama:11434
LLM_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# Optional: HuggingFace token for higher rate limits when downloading embedding models.
# sentence-transformers reads this from the environment automatically.
HF_TOKEN=

# AWS Bedrock — required for LongMemEval answer generation and judging.
# Enable the model in the AWS Bedrock console before first use.
# Model IDs vary by region; us-east-1 has the broadest availability.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
BEDROCK_JUDGE_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
